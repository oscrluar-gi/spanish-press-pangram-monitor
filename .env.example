# Copy this file to .env and put your real key there.
# Never commit .env to GitHub.
PANGRAM_API_KEY=
PRESS_MONITOR_DB=data/press_monitor.sqlite
# Use an identifiable user-agent and replace the contact with your project/contact email.
PRESS_MONITOR_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36 SpanishPressPangramMonitor/0.1 (+research; contact: you@example.com)
PRESS_MONITOR_TIMEOUT_SECONDS=20
PRESS_MONITOR_DOMAIN_PAUSE_SECONDS=1.5
PRESS_MONITOR_EXTRACT_CONCURRENCY=3
PRESS_MONITOR_MAX_CONCURRENCY_PER_DOMAIN=1
PRESS_MONITOR_MIN_WORDS=150
PRESS_MONITOR_RESPECT_ROBOTS=true
PRESS_MONITOR_MAX_SITEMAPS_PER_DOMAIN=30
PRESS_MONITOR_MAX_URLS_PER_DOMAIN=20000
PRESS_MONITOR_MAX_RETRIES=2
PANGRAM_TIMEOUT_SECONDS=30
PANGRAM_MAX_RETRIES=3
PANGRAM_FRAGMENT_MIN_COUNT=2
PANGRAM_FRAGMENT_MAX_COUNT=3
PANGRAM_FRAGMENT_MIN_WORDS=300
PANGRAM_FRAGMENT_MAX_WORDS=500
# Optional deterministic sampling for tests/reproducible local experiments.
# Leave empty/unset for normal random sampling.
PANGRAM_FRAGMENT_RANDOM_SEED=
# Optional deterministic media-level article sampling for reproducible experiments.
# Leave empty/unset for normal random sampling.
PANGRAM_ARTICLE_SAMPLE_SEED=

# Optional Wayback fallback
WAYBACK_ENABLED=true
WAYBACK_STRATEGY=fallback_only
WAYBACK_MAX_DAYS_AFTER=7
WAYBACK_MAX_DAYS_BEFORE=1
WAYBACK_REQUEST_DELAY_SECONDS=1.5
WAYBACK_MAX_RETRIES=2
WAYBACK_USE_CDX=true
WAYBACK_USE_AVAILABILITY=true

# Optional GDELT discovery
GDELT_ENABLED=true
GDELT_MAX_RESULTS_PER_MEDIA=100
GDELT_REQUEST_DELAY_SECONDS=12
GDELT_MAX_RETRIES=2
GDELT_RETRY_DELAY_SECONDS=15
GDELT_TIMEOUT_SECONDS=30
